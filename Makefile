	$(BUILD)/Vzvk_sha2ms/Vtb_sha2ms_kat
	verilator $(ZVK_TB_FLAGS) -Mdir $(BUILD)/Vzvk_sm4 \
		rtl/zvk/sboxes.v rtl/zvk/sm4_encdec.v rtl/zvk/sm4_key_expansion.v \
